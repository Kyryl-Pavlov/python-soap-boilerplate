{
  "info": {
    "name": "Python SOAP Boilerplate",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "SOAP service at /soap. Run Register → Login (auto-captures tokens) → any protected operation."
  },
  "variable": [
    { "key": "base_url",             "value": "http://localhost" },
    { "key": "access_token",         "value": "" },
    { "key": "refresh_token",        "value": "" },
    { "key": "media_id",             "value": "" },
    { "key": "upload_filename",      "value": "test.png",
      "description": "Filename sent with Upload Media. Change to match your file." },
    { "key": "upload_file_data_b64", "value": "",
      "description": "Base64-encoded file content. Leave empty to use the built-in 1x1 PNG. To use your own file paste the output of: macOS/Linux: base64 -i yourfile.jpg | tr -d '\\n'  |  Windows PS: [Convert]::ToBase64String([IO.File]::ReadAllBytes('C:\\path\\file.jpg'))" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Get Health",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/xml;charset=UTF-8" }],
            "url": { "raw": "{{base_url}}/soap", "host": ["{{base_url}}"], "path": ["soap"] },
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope\n  xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\"\n  xmlns:tns=\"urn:flask-soap-boilerplate\">\n  <soapenv:Header/>\n  <soapenv:Body>\n    <tns:get_health/>\n  </soapenv:Body>\n</soapenv:Envelope>"
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/xml;charset=UTF-8" }],
            "url": { "raw": "{{base_url}}/soap", "host": ["{{base_url}}"], "path": ["soap"] },
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope\n  xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\"\n  xmlns:tns=\"urn:flask-soap-boilerplate\">\n  <soapenv:Header/>\n  <soapenv:Body>\n    <tns:register>\n      <tns:email>user@example.com</tns:email>\n      <tns:password>Password123!</tns:password>\n    </tns:register>\n  </soapenv:Body>\n</soapenv:Envelope>"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const xml = pm.response.text();",
                  "pm.test('Login succeeded (no Fault)', () => pm.expect(xml).to.not.include('Fault'));",
                  "const at = (xml.match(/<(?:\\w+:)?access_token[^>]*>([^<]+)</) || [])[1];",
                  "const rt = (xml.match(/<(?:\\w+:)?refresh_token[^>]*>([^<]+)</) || [])[1];",
                  "if (at) { pm.collectionVariables.set('access_token', at.trim()); pm.test('access_token captured', () => pm.expect(at.trim()).to.not.be.empty); }",
                  "if (rt) { pm.collectionVariables.set('refresh_token', rt.trim()); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/xml;charset=UTF-8" }],
            "url": { "raw": "{{base_url}}/soap", "host": ["{{base_url}}"], "path": ["soap"] },
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope\n  xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\"\n  xmlns:tns=\"urn:flask-soap-boilerplate\">\n  <soapenv:Header/>\n  <soapenv:Body>\n    <tns:login>\n      <tns:email>user@example.com</tns:email>\n      <tns:password>Password123!</tns:password>\n    </tns:login>\n  </soapenv:Body>\n</soapenv:Envelope>"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/xml;charset=UTF-8" }],
            "url": { "raw": "{{base_url}}/soap", "host": ["{{base_url}}"], "path": ["soap"] },
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope\n  xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\"\n  xmlns:tns=\"urn:flask-soap-boilerplate\">\n  <soapenv:Header/>\n  <soapenv:Body>\n    <tns:refresh_token>\n      <tns:refresh_token>{{refresh_token}}</tns:refresh_token>\n    </tns:refresh_token>\n  </soapenv:Body>\n</soapenv:Envelope>"
            }
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Publish Event",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/xml;charset=UTF-8" }],
            "url": { "raw": "{{base_url}}/soap", "host": ["{{base_url}}"], "path": ["soap"] },
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope\n  xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\"\n  xmlns:tns=\"urn:flask-soap-boilerplate\">\n  <soapenv:Header>\n    <tns:AuthHeader>\n      <tns:access_token>{{access_token}}</tns:access_token>\n    </tns:AuthHeader>\n  </soapenv:Header>\n  <soapenv:Body>\n    <tns:publish_event>\n      <tns:event_type>user.created</tns:event_type>\n      <tns:payload>{\"user_id\": \"123\"}</tns:payload>\n    </tns:publish_event>\n  </soapenv:Body>\n</soapenv:Envelope>"
            }
          }
        },
        {
          "name": "List Events",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/xml;charset=UTF-8" }],
            "url": { "raw": "{{base_url}}/soap", "host": ["{{base_url}}"], "path": ["soap"] },
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope\n  xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\"\n  xmlns:tns=\"urn:flask-soap-boilerplate\">\n  <soapenv:Header>\n    <tns:AuthHeader>\n      <tns:access_token>{{access_token}}</tns:access_token>\n    </tns:AuthHeader>\n  </soapenv:Header>\n  <soapenv:Body>\n    <tns:list_events/>\n  </soapenv:Body>\n</soapenv:Envelope>"
            }
          }
        }
      ]
    },
    {
      "name": "Cache",
      "item": [
        {
          "name": "Cache Ping",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/xml;charset=UTF-8" }],
            "url": { "raw": "{{base_url}}/soap", "host": ["{{base_url}}"], "path": ["soap"] },
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope\n  xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\"\n  xmlns:tns=\"urn:flask-soap-boilerplate\">\n  <soapenv:Header/>\n  <soapenv:Body>\n    <tns:cache_ping/>\n  </soapenv:Body>\n</soapenv:Envelope>"
            }
          }
        },
        {
          "name": "Cache Test (round-trip)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/xml;charset=UTF-8" }],
            "url": { "raw": "{{base_url}}/soap", "host": ["{{base_url}}"], "path": ["soap"] },
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope\n  xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\"\n  xmlns:tns=\"urn:flask-soap-boilerplate\">\n  <soapenv:Header>\n    <tns:AuthHeader>\n      <tns:access_token>{{access_token}}</tns:access_token>\n    </tns:AuthHeader>\n  </soapenv:Header>\n  <soapenv:Body>\n    <tns:cache_test>\n      <tns:key>flask-soap-boilerplate-test</tns:key>\n      <tns:value>hello-from-postman</tns:value>\n    </tns:cache_test>\n  </soapenv:Body>\n</soapenv:Envelope>"
            }
          }
        }
      ]
    },
    {
      "name": "Media",
      "item": [
        {
          "name": "Upload Media",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// ─── HOW TO PROVIDE YOUR OWN FILE ───────────────────────────────────────────",
                  "// 1. Base64-encode your file with one of these commands:",
                  "//    macOS / Linux : base64 -i /path/to/file.jpg | tr -d '\\n'",
                  "//    Windows PS   : [Convert]::ToBase64String([IO.File]::ReadAllBytes('C:\\path\\file.jpg'))",
                  "// 2. Copy the output.",
                  "// 3. Open Collection → Variables → set 'upload_file_data_b64' current value → Save.",
                  "// 4. Also set 'upload_filename' to the real filename (e.g. photo.jpg).",
                  "// ─────────────────────────────────────────────────────────────────────────────",
                  "",
                  "const TEST_PNG_1X1 = 'iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==';",
                  "",
                  "const userB64  = pm.collectionVariables.get('upload_file_data_b64');",
                  "const userFile = pm.collectionVariables.get('upload_filename');",
                  "",
                  "if (userB64 && userB64.trim().length > 0) {",
                  "    // User provided a real file — use it.",
                  "    pm.variables.set('_b64',  userB64.trim());",
                  "    pm.variables.set('_name', userFile && userFile.trim() ? userFile.trim() : 'upload.bin');",
                  "    console.log('Upload Media: using user-provided file \"' + pm.variables.get('_name') + '\" (' + userB64.trim().length + ' base64 chars)');",
                  "} else {",
                  "    // No file provided — use test PNG and print instructions.",
                  "    pm.variables.set('_b64',  TEST_PNG_1X1);",
                  "    pm.variables.set('_name', 'test.png');",
                  "    console.warn('Upload Media: no file set — using built-in 1×1 test PNG.');",
                  "    console.warn('To upload your own file, set collection variable \"upload_file_data_b64\" (see request description).');",
                  "}",
                  "",
                  "// Inject the resolved values into the SOAP body.",
                  "const raw = pm.request.body.raw",
                  "    .replace('{{upload_filename}}',      pm.variables.get('_name'))",
                  "    .replace('{{upload_file_data_b64}}', pm.variables.get('_b64'));",
                  "pm.request.body.raw = raw;"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const xml = pm.response.text();",
                  "pm.test('Upload succeeded (no Fault)', () => pm.expect(xml).to.not.include('Fault'));",
                  "const mid = (xml.match(/<(?:\\w+:)?media_id[^>]*>([^<]+)</) || [])[1];",
                  "if (mid) { pm.collectionVariables.set('media_id', mid.trim()); pm.test('media_id captured', () => pm.expect(mid.trim()).to.not.be.empty); }",
                  "const rawUrl = (xml.match(/<(?:\\w+:)?url[^>]*>([^<]+)</) || [])[1];",
                  "if (rawUrl) {",
                  "    const url = rawUrl.trim().replace(/&amp;/g, '&');",
                  "    pm.collectionVariables.set('media_url', url);",
                  "    pm.visualizer.set('<a href=\"{{url}}\" target=\"_blank\" style=\"word-break:break-all;font-family:monospace\">{{url}}</a>', { url });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/xml;charset=UTF-8" }],
            "url": { "raw": "{{base_url}}/soap", "host": ["{{base_url}}"], "path": ["soap"] },
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope\n  xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\"\n  xmlns:tns=\"urn:flask-soap-boilerplate\">\n  <soapenv:Header>\n    <tns:AuthHeader>\n      <tns:access_token>{{access_token}}</tns:access_token>\n    </tns:AuthHeader>\n  </soapenv:Header>\n  <soapenv:Body>\n    <tns:upload_media>\n      <tns:filename>{{upload_filename}}</tns:filename>\n      <tns:file_data_b64>{{upload_file_data_b64}}</tns:file_data_b64>\n      <tns:content_type>image/png</tns:content_type>\n    </tns:upload_media>\n  </soapenv:Body>\n</soapenv:Envelope>"
            }
          }
        },
        {
          "name": "Get Media URL",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const xml = pm.response.text();",
                  "pm.test('Get URL succeeded (no Fault)', () => pm.expect(xml).to.not.include('Fault'));",
                  "const rawUrl = (xml.match(/<(?:\\w+:)?url[^>]*>([^<]+)</) || [])[1];",
                  "if (rawUrl) {",
                  "    const url = rawUrl.trim().replace(/&amp;/g, '&');",
                  "    pm.collectionVariables.set('media_url', url);",
                  "    pm.visualizer.set('<a href=\"{{url}}\" target=\"_blank\" style=\"word-break:break-all;font-family:monospace\">{{url}}</a>', { url });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/xml;charset=UTF-8" }],
            "url": { "raw": "{{base_url}}/soap", "host": ["{{base_url}}"], "path": ["soap"] },
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope\n  xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\"\n  xmlns:tns=\"urn:flask-soap-boilerplate\">\n  <soapenv:Header>\n    <tns:AuthHeader>\n      <tns:access_token>{{access_token}}</tns:access_token>\n    </tns:AuthHeader>\n  </soapenv:Header>\n  <soapenv:Body>\n    <tns:get_media_url>\n      <tns:media_id>{{media_id}}</tns:media_id>\n    </tns:get_media_url>\n  </soapenv:Body>\n</soapenv:Envelope>"
            }
          }
        }
      ]
    }
  ]
}
